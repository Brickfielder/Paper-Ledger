---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const papers = await getCollection("papers", ({ data }) => !data.draft);

const hingeSlug = "spiking-the-mind-rethinking-the-role-of-cortical-feedback-in-visual-mental-imagery";
const hingePaper = papers.find((paper) => paper.slug === hingeSlug);

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Hinges | Paper Ledger"
  description="Conceptual hinge papers that change how we frame a field."
>
  <section class="landing-intro">
    <p class="eyebrow">Hinges</p>
    <h1 class="page-title">Hinge Papers</h1>
    <p class="page-intro">
      Papers that act as conceptual pivots: not just new data points, but new
      organizing lenses.
    </p>
  </section>

  <section class="section">
    {hingePaper ? (
      <article class="paper-item">
        <div class="paper-item__top">
          <a href={`${basePath}papers/${hingePaper.slug}/`}>
            <h3>{hingePaper.data.title}</h3>
          </a>
        </div>

        <p class="paper-summary">
          This hinge paper reframes visual imagery as spontaneous-activity
          reshaping in early visual cortex, arguing that top-down feedback is
          usually modulatory rather than spike-driving and explaining why
          imagery is weaker, slower, and more priming-like than perception.
        </p>

        <div class="paper-meta paper-meta--landing">
          {hingePaper.data.year && <span>{hingePaper.data.year}</span>}
          {hingePaper.data.journal && <span>{hingePaper.data.journal}</span>}
          <span>{hingePaper.data.sourceHost}</span>
        </div>
      </article>
    ) : (
      <p class="page-intro">No hinge papers have been pinned yet.</p>
    )}
  </section>
</BaseLayout>
