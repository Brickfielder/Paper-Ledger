---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const papers = await getCollection("papers", ({ data }) => !data.draft);

const highlightEntries = [
  {
    slug: "hierarchical-x-ray-microscopy-and-mesoscopic-diffusion-mri-in-the-same-brain-reveal-the-human-connectome-across-scales",
    summary:
      "A standout cross-scale connectomics paper: the same human hemisphere is followed from MRI-scale tractography through hierarchical X-ray microscopy, micro-CT, and electron microscopy, creating a bridge between whole-brain maps and microscopic axonal anatomy.",
  },
  {
    slug: "functional-recovery-of-the-adult-murine-hippocampus-after-cryopreservation-by-vi",
    summary:
      "A striking preservation result: adult mouse hippocampal tissue is vitrified, rewarmed, and shown to recover short-term structure, metabolism, excitability, synaptic transmission, and long-term potentiation after molecular mobility had effectively stopped.",
  },
];

const highlightPapers = highlightEntries
  .map((entry) => {
    const paper = papers.find((item) => item.slug === entry.slug);
    return paper ? { paper, summary: entry.summary } : null;
  })
  .filter((entry): entry is { paper: (typeof papers)[number]; summary: string } => Boolean(entry));

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Highlights | Paper Ledger"
  description="Selected papers worth foregrounding from the archive."
>
  <section class="landing-intro">
    <p class="eyebrow">Highlights</p>
    <h1 class="page-title">Highlights</h1>
    <p class="page-intro">
      Selected papers worth keeping close at hand.
    </p>
  </section>

  <section class="section">
    {highlightPapers.length > 0 ? (
      highlightPapers.map(({ paper, summary }) => (
        <article class="paper-item">
          <div class="paper-item__top">
            <a href={`${basePath}papers/${paper.slug}/`}>
              <h3>{paper.data.title}</h3>
            </a>
          </div>

          <p class="paper-summary">{summary}</p>

          <div class="paper-meta paper-meta--landing">
            {paper.data.year && <span>{paper.data.year}</span>}
            {paper.data.journal && <span>{paper.data.journal}</span>}
            <span>{paper.data.sourceHost}</span>
          </div>
        </article>
      ))
    ) : (
      <p class="page-intro">No highlights have been pinned yet.</p>
    )}
  </section>
</BaseLayout>
