---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const papers = await getCollection("papers", ({ data }) => !data.draft);

const hingeEntries = [
  {
    slug: "spiking-the-mind-rethinking-the-role-of-cortical-feedback-in-visual-mental-imagery",
    summary:
      "This hinge paper reframes visual imagery as spontaneous-activity reshaping in early visual cortex, arguing that top-down feedback is usually modulatory rather than spike-driving and explaining why imagery is weaker, slower, and more priming-like than perception.",
  },
  {
    slug: "backpropagation-and-the-brain",
    summary:
      "This hinge paper reframes the backprop debate from a literal yes/no question to a functional one, arguing that cortical feedback may encode activity differences (NGRAD) that approximate gradient-like credit assignment without requiring textbook backprop in cortex.",
  },
];

const hingePapers = hingeEntries
  .map((entry) => {
    const paper = papers.find((item) => item.slug === entry.slug);
    return paper ? { paper, summary: entry.summary } : null;
  })
  .filter((entry): entry is { paper: (typeof papers)[number]; summary: string } => Boolean(entry));

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Hinges | Paper Ledger"
  description="Conceptual hinge papers that change how we frame a field."
>
  <section class="landing-intro">
    <p class="eyebrow">Hinges</p>
    <h1 class="page-title">Hinge Papers</h1>
    <p class="page-intro">
      Papers that act as conceptual pivots: not just new data points, but new
      organizing lenses.
    </p>
  </section>

  <section class="section">
    {hingePapers.length > 0 ? (
      hingePapers.map(({ paper, summary }) => (
        <article class="paper-item">
          <div class="paper-item__top">
            <a href={`${basePath}papers/${paper.slug}/`}>
              <h3>{paper.data.title}</h3>
            </a>
          </div>

          <p class="paper-summary">{summary}</p>

          <div class="paper-meta paper-meta--landing">
            {paper.data.year && <span>{paper.data.year}</span>}
            {paper.data.journal && <span>{paper.data.journal}</span>}
            <span>{paper.data.sourceHost}</span>
          </div>
        </article>
      ))
    ) : (
      <p class="page-intro">No hinge papers have been pinned yet.</p>
    )}
  </section>
</BaseLayout>
