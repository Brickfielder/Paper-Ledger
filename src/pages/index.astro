---
import { getCollection } from "astro:content";
import { expandPaperTags, groupTagsByRoot, normalizePaperTags } from "../lib/tag-taxonomy.mjs";
import BaseLayout from "../layouts/BaseLayout.astro";

const papers = (await getCollection("papers", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.capturedAt.getTime() - a.data.capturedAt.getTime(),
);

const tagGroups = groupTagsByRoot([...new Set(papers.flatMap((paper) => expandPaperTags(paper.data.tags)))]);
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);

const sentenceSegmenter = new Intl.Segmenter("en", { granularity: "sentence" });
const excerptSummary = (summary: string) => {
  const sentences = [...sentenceSegmenter.segment(summary)].map((segment) => segment.segment.trim());
  return (sentences.length > 0 ? sentences : [summary])
    .slice(0, 2)
    .filter(Boolean)
    .join(" ");
};
---

<BaseLayout
  title="Paper Ledger"
  description="A portable scientific reading archive with automatic summaries and tagging."
>
  <section class="landing-intro">
    <h1 class="page-title">Paper Ledger</h1>
    <p class="page-intro">A reading archive for papers worth keeping.</p>
  </section>

  <section class="section">
    {papers.length === 0 ? (
      <p class="page-intro">No paper summaries yet. Add a DOI or article URL to `inbox/` and run the processor.</p>
    ) : (
      <ol class="paper-list paper-list--landing">
        {papers.map((paper) => (
          <li class="paper-item paper-item--landing">
            <div class="paper-item__top">
              <a href={`${basePath}papers/${paper.slug}/`}>
                <h3>{paper.data.title}</h3>
              </a>
              <span class="paper-item__date">{formatDate(paper.data.capturedAt)}</span>
            </div>
            <p class="paper-summary">{excerptSummary(paper.data.summary)}</p>
            <div class="paper-meta paper-meta--landing">
              {paper.data.year && <span>{paper.data.year}</span>}
              {paper.data.doi ? <span>DOI available</span> : <span>Web source only</span>}
              <span>{paper.data.tags.length} {paper.data.tags.length === 1 ? "tag" : "tags"}</span>
            </div>
            <div class="paper-tags">
              {normalizePaperTags(paper.data.tags).map((tag) => (
                <a class="tag" href={`${basePath}tags/${tag}/`}>
                  {tag}
                </a>
              ))}
            </div>
          </li>
        ))}
      </ol>
    )}
  </section>

  <section class="section section--tags" id="tags">
    <p class="section-kicker">Tag index</p>
    <div class="tag-taxonomy">
      {tagGroups.length === 0 ? (
        <p class="section-kicker">Tags will appear here once the first summaries are processed.</p>
      ) : (
        tagGroups.map((group) => (
          <section class="tag-family">
            <a class="tag-family__root" href={`${basePath}tags/${group.root}/`}>
              {group.root}
            </a>
            <div class="tag-family__list">
              {group.entries
                .filter((entry) => entry.tag !== group.root)
                .map((entry) => (
                  <a
                    class={`tag tag--depth-${Math.min(entry.depth, 3)}`}
                    href={`${basePath}tags/${entry.tag}/`}
                  >
                    {entry.tag}
                  </a>
                ))}
            </div>
          </section>
        ))
      )}
    </div>
  </section>
</BaseLayout>
