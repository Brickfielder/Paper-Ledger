---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const papers = (await getCollection("papers", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.capturedAt.getTime() - a.data.capturedAt.getTime(),
);

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);

const sentenceSegmenter = new Intl.Segmenter("en", { granularity: "sentence" });
const excerptSummary = (summary: string) => {
  const sentences = [...sentenceSegmenter.segment(summary)].map((segment) => segment.segment.trim());
  return (sentences.length > 0 ? sentences : [summary])
    .slice(0, 2)
    .filter(Boolean)
    .join(" ");
};

const searchablePapers = papers.map((paper) => ({
  paper,
  searchText: [
    paper.data.title,
    paper.data.summary,
    paper.data.whyItMatters,
    paper.data.limitations || "",
    paper.data.authors.join(" "),
    paper.data.journal || "",
    paper.data.doi || "",
    paper.data.theme || "",
    paper.data.sourceHost,
  ]
    .join(" ")
    .toLowerCase(),
}));

const themeCounts = Array.from(
  papers.reduce((counts, paper) => {
    const theme = paper.data.theme || "Uncategorized";
    counts.set(theme, (counts.get(theme) || 0) + 1);
    return counts;
  }, new Map<string, number>()),
)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8);

const sourceCount = new Set(papers.map((paper) => paper.data.sourceHost)).size;
const years = papers
  .map((paper) => paper.data.year)
  .filter((year): year is number => typeof year === "number")
  .sort((a, b) => a - b);
const yearRange =
  years.length > 1 ? `${years[0]}-${years[years.length - 1]}` : years[0]?.toString() || "Current";

const themeSlug = (name: string) =>
  name.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

---

<BaseLayout
  title="Paper Ledger"
  description="A portable scientific reading archive with instant search."
>
  <section class="home-banner" aria-label="Paper Ledger motto">
    <img
      src={`${basePath}paper-ledger-banner.png`}
      alt="Paper Ledger banner: You should always seek out proof. And you should never stop asking questions."
      width="1280"
      height="382"
      fetchpriority="high"
    />
  </section>

  <div class="ledger-home">
    <div class="ledger-main">
      <section class="landing-intro landing-intro--home">
        <p class="eyebrow">Paper Ledger</p>
        <h1 class="page-title">A reading archive for papers worth keeping.</h1>
        {papers.length > 0 && (
          <div class="search-panel" role="search">
            <label class="search-label" for="paper-search">Search the archive</label>
            <div class="search-field">
              <input
                id="paper-search"
                class="search-input"
                type="search"
                name="q"
                placeholder="Search title, author, DOI, or theme"
                autocomplete="off"
                data-paper-search
              />
              <span class="search-key" aria-hidden="true">Ctrl K</span>
            </div>
            <p class="search-status" data-search-status aria-live="polite">{papers.length} papers in the archive.</p>
          </div>
        )}
      </section>

      <section class="section">
        {papers.length === 0 ? (
          <p class="page-intro">No paper summaries yet. Add a DOI or article URL to `inbox/` and run the processor.</p>
        ) : (
          <>
            <div class="section-heading">
              <h2>Recent summaries</h2>
              <p class="search-empty" data-search-empty hidden aria-live="polite">
                No papers match that search yet.
              </p>
            </div>

            <ol class="paper-list paper-list--landing" data-paper-results>
              {searchablePapers.map(({ paper, searchText }, index) => (
                <li class="paper-item paper-item--landing" data-paper-card data-search={searchText}>
                  <a class="paper-item__link" href={`${basePath}papers/${paper.slug}/`}>
                    <span class="paper-item__index">{String(index + 1).padStart(2, "0")}</span>
                    <span class="paper-item__body">
                      <span class="paper-item__top">
                        <h3>{paper.data.title}</h3>
                        <span class="paper-item__date">{formatDate(paper.data.capturedAt)}</span>
                      </span>
                      <span class="paper-summary">{excerptSummary(paper.data.summary)}</span>
                      <span class="paper-meta paper-meta--landing">
                        {paper.data.year && <span>{paper.data.year}</span>}
                        {paper.data.journal && <span>{paper.data.journal}</span>}
                        {paper.data.theme && <span>{paper.data.theme}</span>}
                        <span>{paper.data.sourceHost}</span>
                      </span>
                    </span>
                    <span class="paper-item__action">Paper Details</span>
                  </a>
                </li>
              ))}
            </ol>
          </>
        )}
      </section>
    </div>

    {papers.length > 0 && (
      <aside class="ledger-sidebar" aria-label="Archive overview">
        <section class="sidebar-panel sidebar-panel--count">
          <p class="sidebar-count">{papers.length} papers</p>
          <dl class="sidebar-stats">
            <div>
              <dt>Summaries</dt>
              <dd>{papers.length}</dd>
            </div>
            <div>
              <dt>Themes</dt>
              <dd>{themeCounts.length}</dd>
            </div>
            <div>
              <dt>Sources</dt>
              <dd>{sourceCount}</dd>
            </div>
            <div>
              <dt>Years</dt>
              <dd>{yearRange}</dd>
            </div>
          </dl>
        </section>

        {themeCounts.length > 0 && (
          <section class="sidebar-panel">
            <h2>Themes</h2>
            <ul class="theme-chip-list">
              {themeCounts.map(([theme, count]) => (
                <li>
                  <a href={`${basePath}themes/#${themeSlug(theme)}`}>{theme}</a>
                  <span>{count}</span>
                </li>
              ))}
            </ul>
            <a class="sidebar-link" href={`${basePath}themes/`}>View all themes</a>
          </section>
        )}

        <section class="sidebar-panel sidebar-quote">
          <p>Good papers deepen understanding. Great ones change how we think.</p>
        </section>
      </aside>
    )}
  </div>
</BaseLayout>

<script is:inline>
  const input = document.querySelector("[data-paper-search]");
  const status = document.querySelector("[data-search-status]");
  const empty = document.querySelector("[data-search-empty]");
  const items = [...document.querySelectorAll("[data-paper-card]")];

  if (input instanceof HTMLInputElement && status && empty) {
    const total = items.length;
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q");

    if (initialQuery) {
      input.value = initialQuery;
    }

    const updateSearch = () => {
      const rawQuery = input.value.trim();
      const query = rawQuery.toLowerCase();
      let visibleCount = 0;

      for (const item of items) {
        const haystack = item instanceof HTMLElement ? item.dataset.search || "" : "";
        const isMatch = query === "" || haystack.includes(query);

        if (item instanceof HTMLElement) {
          item.hidden = !isMatch;
        }

        if (isMatch) {
          visibleCount += 1;
        }
      }

      status.textContent = query
        ? `${visibleCount} of ${total} papers match "${rawQuery}".`
        : `${total} papers in the archive.`;
      empty.hidden = visibleCount !== 0;

      const url = new URL(window.location.href);
      if (query) {
        url.searchParams.set("q", rawQuery);
      } else {
        url.searchParams.delete("q");
      }
      history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);
    };

    input.addEventListener("input", updateSearch);
    document.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        input.focus();
      }
    });
    updateSearch();
  }
</script>
