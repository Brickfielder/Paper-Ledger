---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Paper Ledger",
  description = "A searchable archive of scientific paper summaries.",
} = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const currentPath = Astro.url.pathname.replace(basePath, "/");
const normalizedPath = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
const navItems = [
  { label: "Latest", href: basePath, path: "/" },
  { label: "Highlights", href: `${basePath}hinges/`, path: "/hinges/" },
  { label: "Themes", href: `${basePath}themes/`, path: "/themes/" },
  { label: "Dictionary", href: `${basePath}dictionary/`, path: "/dictionary/" },
  { label: "Conference notes", href: `${basePath}conference-notes/`, path: "/conference-notes/" },
  { label: "Tools", href: `${basePath}tools/`, path: "/tools/" },
  { label: "About", href: `${basePath}about/`, path: "/about/" },
];

const isActive = (path: string) =>
  path === "/" ? normalizedPath === "/" : normalizedPath.startsWith(path);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="shell site-header__row">
        <a class="brand" href={basePath}>
          <span class="brand__mark" aria-hidden="true">PL</span>
          <span class="brand__name">Paper Ledger</span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} aria-current={isActive(item.path) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="shell">
      <slot />
    </main>

    <footer class="shell footer">
      Built for low-friction capture: drop a DOI or article URL into `inbox/` and let automation do the rest.
    </footer>
  </body>
</html>
